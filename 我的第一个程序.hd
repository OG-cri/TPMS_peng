//{playid:1020,voice:十}

void play_digit(uint8_t d)
{
  if (d <= 9) play_audio(1010 + d);
}

void say_number_cn(uint8_t n)
{
  if (n == 0) { play_digit(0); return; }
  if (n < 10) { play_digit(n); return; }
  if (n < 20) {
    play_audio(1020);
    if (n > 10) play_digit(n - 10);
    return;
  }
  play_digit(n / 10);
  play_audio(1020);
  if (n % 10) play_digit(n % 10);
}

void Voice_AnnounceTireStatus(uint8_t status, uint8_t tire_id)
{
  if (status == 0) {
    play_audio(10006);
  } else if (status == 3) {
    play_audio(1021);
    delay(300);
    say_number_cn(tire_id);
    delay(300);
    play_audio(1022);
  } else {
    play_audio(10007);
    delay(300);
    say_number_cn(tire_id);
    delay(300);
    if (status == 1) {
      play_audio(10011);
    } else if (status == 2) {
      play_audio(10012);
    } else {
      play_audio(10008);
    }
  }
}

void Voice_OnTireAlert(uint8_t status, uint8_t tire_id)
{
  if (status == 0) return;
  set_state_enter_wakeup(10000);
  Voice_AnnounceTireStatus(status, tire_id);
}

void Voice_ParseByte(uint8_t data)
{
  if (rx_index == 0 && data == 0xAA) {
    rx_buf[0] = data;
    rx_index = 1;
  } else if (rx_index > 0) {
    rx_buf[rx_index++] = data;
    if (rx_index >= 5) {
      uint8_t sum = rx_buf[0] + rx_buf[1] + rx_buf[2] + rx_buf[3];
      if (sum == rx_buf[4]) {
        if (rx_buf[1] == 0x01 && s_time_query_pending) {
          frame_ready = 1;
        } else if (rx_buf[1] == 0x02) {
          if (s_tire_query_pending) {
            frame_ready = 1;
          } else if (rx_buf[2] != 0) {
            Voice_OnTireAlert(rx_buf[2], rx_buf[3]);
          }
        }
      }
      rx_index = 0;
    }
  }
}

void Voice_DrainUart(void)
{
  while (STM32_UART.available()) {
    Voice_ParseByte(STM32_UART.read());
  }
}

void Voice_AnnounceVolume(void)
{
  play_audio(10014);
  delay(300);
  say_number_cn(s_volume);
}

void ASR_CODE(){
  set_state_enter_wakeup(10000);

  switch (snid) {
    case 1: digitalWrite(4, 0); break;
    case 2: digitalWrite(4, 1); break;
    case 5:
    case 8:
      STM32_UART.write(0x01);
      Voice_ProcessTime();
      break;
    case 6:
    case 7:
      STM32_UART.write(0x02);
      Voice_ProcessTire();
      break;
    case 9:
      Voice_AnnounceVolume();
      break;
    case 10:
      if (s_volume < 10) s_volume++;
      vol_set(s_volume);
      play_audio(10015);
      delay(300);
      say_number_cn(s_volume);
      break;
    case 11:
      if (s_volume > 0) s_volume--;
      vol_set(s_volume);
      play_audio(10015);
      delay(300);
      say_number_cn(s_volume);
      break;
  }

  if (snid == 3) digitalWrite(4, 0);
  if (snid == 4) digitalWrite(4, 1);
}

void Voice_ProcessTime(void)
{
  uint8_t timeout = 100;
  frame_ready = 0;
  rx_index = 0;
  s_time_query_pending = 1;

  while (timeout--) {
    Voice_DrainUart();
    if (frame_ready) break;
    delay(10);
  }

  s_time_query_pending = 0;

  if (frame_ready) {
    frame_ready = 0;
    play_audio(10003);
    delay(300);
    say_number_cn(rx_buf[2]);
    delay(300);
    play_audio(10004);
    delay(300);
    say_number_cn(rx_buf[3]);
    delay(300);
    play_audio(10005);
  } else {
    play_audio(10009);
  }
}

void Voice_ProcessTire(void)
{
  uint8_t timeout = 100;
  frame_ready = 0;
  rx_index = 0;
  s_tire_query_pending = 1;

  while (timeout--) {
    Voice_DrainUart();
    if (frame_ready) break;
    delay(10);
  }

  s_tire_query_pending = 0;

  if (frame_ready) {
    frame_ready = 0;
    Voice_AnnounceTireStatus(rx_buf[2], rx_buf[3]);
  } else {
    play_audio(10010);
  }
}

void hardware_init(){
  vol_set(6);
  setPinFun(2, FORTH_FUNCTION);
  setPinFun(3, FORTH_FUNCTION);
  STM32_UART.begin(115200);
  xTaskCreate(stm32_rx_task, "stm32_rx", 512, NULL, 2, NULL);
  vTaskDelete(NULL);
}

void stm32_rx_task(void *pv)
{
  (void)pv;
  while (1) {
    Voice_DrainUart();
    delay(10);
  }
}

void loop()
{
  Voice_DrainUart();
  delay(10);
}

void serialEvent1()
{
  Voice_DrainUart();
}

