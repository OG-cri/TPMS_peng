#include "asr.h"
extern "C"{ void * __dso_handle = 0 ;}
#include "setup.h"
#include "HardwareSerial.h"
#include "myLib/asr_event.h"

uint32_t snid;
void ASR_CODE();

#define STM32_UART Serial1

uint8_t rx_buf[10];
uint8_t rx_index = 0;
uint8_t frame_ready = 0;
static uint8_t s_tire_query_pending = 0;
static uint8_t s_time_query_pending = 0;

// 当前音量 (0-10)
static uint8_t s_volume = 6;

void Voice_ProcessTime(void);
void Voice_ProcessTire(void);
void play_digit(uint8_t d);
void say_number_cn(uint8_t n);
void Voice_ParseByte(uint8_t data);
void Voice_AnnounceTireStatus(uint8_t status, uint8_t tire_id);
void Voice_DrainUart(void);
void Voice_OnTireAlert(uint8_t status, uint8_t tire_id);
void Voice_AnnounceVolume(void);
void stm32_rx_task(void *pv);

//{speak:小蝶-清新女声,vol:6,speed:10,platform:haohaodada}
